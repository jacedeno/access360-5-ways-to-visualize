# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Timezone for all stack containers.
TZ=UTC

# InfluxDB 3 admin token — generate one for your instance, e.g.:
#   docker exec iot-influxdb3 influxdb3 create token --admin
# The InfluxDB 3 UI uses it as DEFAULT_API_TOKEN; methods that write/read use it too.
INFLUXDB3_ADMIN_TOKEN=apiv3_replace-me

# InfluxDB 3 UI session secret — any long random string (persists UI sessions).
INFLUXDB3_UI_SESSION_SECRET=replace-with-a-long-random-string

# Grafana admin login.
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=replace-me
