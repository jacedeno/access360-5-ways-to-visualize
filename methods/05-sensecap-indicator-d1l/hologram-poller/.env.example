# Copy to .env and fill in the real values. .env is gitignored.
#
# Hologram dashboard API key (secret). Get it from the Hologram dashboard
# (Settings -> API keys). NEVER commit the real key.
HOLOGRAM_API_KEY=replace-me

# Optional: pin a specific device/SIM id. Leave empty to use the first device on
# the account.
HOLOGRAM_DEVICE_ID=

# Optional overrides (defaults shown):
# HOLOGRAM_API_BASE=https://dashboard.hologram.io/api/1
# MQTT_HOST=iot-hivemq
# MQTT_PORT=1883
# GATEWAY_SN=43250372
# POLL_INTERVAL_S=300
# Best-effort response-key overrides if your account uses different field names:
# HOLOGRAM_USED_KEY=cur_billing_data_used
# HOLOGRAM_LIMIT_KEY=overagelimit
