    {
      "id": 13,
      "type": "timeseries",
      "title": "Vibration velocity \u2014 Z RMS (in/s) by sensor",
      "description": "Per-sensor Z-axis velocity RMS (IPS). Overlay to compare amplitude between machines; ISO-10816 territory.",
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUX_UID}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUX_UID}"
          },
          "rawSql": "SELECT date_bin(interval '30 seconds', time) AS time, sensor_id, avg(vel_z_rms) AS vel_z FROM vibration WHERE gateway_sn='43250372' AND sensor_id IN (${sensor:singlequote}) AND vel_z_rms IS NOT NULL AND time >= now() - interval '6 hours' GROUP BY 1, sensor_id ORDER BY 1",
          "resultFormat": "table",
          "rawQuery": true
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "suffix: in/s",
          "custom": {
            "drawStyle": "line",
            "showPoints": "always",
            "pointSize": 7,
            "lineInterpolation": "linear",
            "spanNulls": true,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": [
            "lastNotNull",
            "max",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Vibration acceleration \u2014 Z RMS (g) by sensor",
      "description": "Per-sensor Z-axis acceleration RMS (g).",
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUX_UID}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUX_UID}"
          },
          "rawSql": "SELECT date_bin(interval '30 seconds', time) AS time, sensor_id, avg(z_rms) AS accel_z FROM vibration WHERE gateway_sn='43250372' AND sensor_id IN (${sensor:singlequote}) AND z_rms IS NOT NULL AND time >= now() - interval '6 hours' GROUP BY 1, sensor_id ORDER BY 1",
          "resultFormat": "table",
          "rawQuery": true
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 9
