    {
      "id": 8,
      "type": "gauge",
      "title": "4G Data Used",
      "description": "Cellular data used vs plan limit (Hologram SIMs).",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROM_UID}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROM_UID}"
          },
          "expr": "100 * sum(hologram_sim_data_used_bytes) / clamp_min(sum(hologram_sim_data_limit_bytes), 1)",
          "instant": true
