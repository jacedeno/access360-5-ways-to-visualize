{
  "uid": "access360-live",
  "title": "ACCESS360 \u2014 Live Fleet Health (MQTT)",
  "tags": [
    "access360",
    "mqtt",
    "live",
    "method-3"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 0,
  "refresh": "",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "### ACCESS360 \u2014 Live Fleet Health (Grafana Live via MQTT)\nStreaming straight from **HiveMQ** (`iot-hivemq:1883`) \u2014 no database in the path. Gateway `43250372`. Panels update as messages arrive over Grafana Live (WebSocket)."
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "BLE RSSI \u2014 live (dBm)",
      "description": "Rssi field from rssi/notify, per message as it streams.",
      "datasource": {
        "type": "grafana-mqtt-datasource",
        "uid": "${DS_MQTT_UID}"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-mqtt-datasource",
            "uid": "${DS_MQTT_UID}"
          },
          "topic": "access360/43250372/rssi/notify",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "custom": {
            "drawStyle": "line",
            "showPoints": "always",
            "pointSize": 6,
            "lineInterpolation": "linear",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Serial"
            },
            "properties": [
              {
                "id": "custom.hideFrom",
                "value": {
                  "viz": true,
                  "legend": true,
                  "tooltip": true
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "ID"
            },
            "properties": [
              {
                "id": "custom.hideFrom",
                "value": {
                  "viz": true,
                  "legend": true,
                  "tooltip": true
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Sensor heartbeats \u2014 live",
