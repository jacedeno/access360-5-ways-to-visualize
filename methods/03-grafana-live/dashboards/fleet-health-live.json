    {
      "id": 6,
      "type": "stat",
      "title": "Battery % (latest)",
      "datasource": {
        "type": "grafana-mqtt-datasource",
        "uid": "${DS_MQTT_UID}"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-mqtt-datasource",
            "uid": "${DS_MQTT_UID}"
          },
          "topic": "access360/43250372/dyn/batt/notify",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 8,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "green",
                "value": 40
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^Batt$/",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "auto",
        "orientation": "auto"
      }
    },
