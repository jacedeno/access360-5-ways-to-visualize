{
  "uid": "access360-live",
  "title": "ACCESS360 \u2014 Live Fleet Health (MQTT)",
  "tags": [
    "access360",
    "mqtt",
    "live",
    "influxdb",
    "method-3"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 0,
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "### ACCESS360 \u2014 Fleet Health\n**Top:** history from **InfluxDB 3** (`spectra`) \u2014 always populated. **Bottom:** **Grafana Live** straight from HiveMQ (no DB) \u2014 fills as sensors stream. Velocity (IPS) live is flattened from the on-demand `dyn/vib/notify` by the Node-RED normalizer."
      }
    },
    {
      "id": 2,
      "type": "row",
      "title": "Fleet history \u2014 InfluxDB 3 (always populated)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "BLE RSSI by sensor \u2014 last 7d",
      "description": "Per-sensor RSSI history (7 days).",
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUX_UID}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUX_UID}"
          },
          "rawSql": "SELECT date_bin(interval '30 minutes', time) AS time, sensor_id, avg(rssi_dbm) AS rssi FROM sensor_health WHERE metric='rssi' AND gateway_sn='43250372' AND time >= now() - interval '7 days' GROUP BY 1, sensor_id ORDER BY 1",
          "resultFormat": "table",
          "rawQuery": true
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 16,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "custom": {
            "drawStyle": "line",
            "showPoints": "always",
            "pointSize": 6,
            "spanNulls": true,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Last recorded velocity \u2014 IPS",
      "description": "Most recent full-reading overall velocity. Full readings are on-demand, so this is the last known value.",
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUX_UID}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUX_UID}"
          },
          "rawSql": "SELECT time, sqrt(vel_x_rms*vel_x_rms + vel_y_rms*vel_y_rms + vel_z_rms*vel_z_rms) AS vel_overall FROM vibration WHERE gateway_sn='43250372' AND vel_x_rms IS NOT NULL AND time >= now() - interval '365 days' ORDER BY time",
          "resultFormat": "table",
          "rawQuery": true
        }
      ],
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "suffix: in/s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.157
              },
              {
                "color": "orange",
                "value": 0.275
              },
              {
                "color": "red",
                "value": 0.44
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^vel_overall$/",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Battery % by sensor (latest)",
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUX_UID}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUX_UID}"
          },
          "rawSql": "SELECT time, sensor_id, battery_pct FROM sensor_health WHERE metric='battery' AND gateway_sn='43250372' AND time >= now() - interval '60 days' ORDER BY time",
          "resultFormat": "table",
          "rawQuery": true
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "green",
                "value": 40
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "displayMode": "gradient",
        "orientation": "horizontal"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Sensors reporting per hour \u2014 7d",
      "description": "Distinct sensors seen each hour (7 days).",
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUX_UID}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUX_UID}"
          },
          "rawSql": "SELECT date_bin(interval '1 hour', time) AS time, count(distinct sensor_id) AS sensors FROM sensor_health WHERE gateway_sn='43250372' AND time >= now() - interval '7 days' GROUP BY 1 ORDER BY 1",
          "resultFormat": "table",
          "rawQuery": true
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "showPoints": "always",
            "pointSize": 6,
            "spanNulls": true,
            "lineWidth": 2
