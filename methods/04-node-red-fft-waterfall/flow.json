  {
    "id": "a360_reasm",
    "type": "function",
    "z": "a360_m4_tab",
    "name": "reassemble + unwrap",
    "func": "// Multipart reassembly + Reading-wrapper unwrap (mirror of lib/reassemble.js)\nvar store = context.get('mp') || {};\nfunction feed(o){\n  if(o==null||typeof o!=='object'||o.MultiPart_ID===undefined) return o;\n  var id=o.MultiPart_ID; var buf=store[id]||(store[id]=[]);\n  buf.push(String(o.Data==null?'':o.Data));\n  try{ var p=JSON.parse(buf.join('')); delete store[id]; return p; }\n  catch(e){ return null; }\n}\nvar parsed = feed(msg.payload);\ncontext.set('mp', store);\nif(parsed==null) return null;\nvar r = (parsed && parsed.Reading && typeof parsed.Reading==='object') ? parsed.Reading : parsed;\nif(!r || !r.Fs || !r.Samples){ node.warn('dyn/vib without waveform fields'); return null; }\nmsg.meta = { serial:r.Serial, id:r.ID, time:r.Time, Fs:r.Fs, Samples:r.Samples };\nmsg.axes = { X:r.X, Y:r.Y, Z:r.Z };\nnode.status({fill:'green',shape:'dot',text:'rd '+r.Serial+' #'+r.ID});\nreturn msg;\n",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 420,
    "y": 120,
    "wires": [
      [
        "a360_fft"
      ]
    ]
  },
  {
    "id": "a360_fft",
    "type": "function",
    "z": "a360_m4_tab",
    "name": "FFT + downsample",
    "func": "// FFT -> single-sided spectrum -> downsample -> one combined payload\nfunction nextPow2(n){var p=1;while(p<n)p<<=1;return p;}\nfunction hann(N){var w=new Float64Array(N);for(var i=0;i<N;i++)w[i]=0.5*(1-Math.cos(2*Math.PI*i/(N-1)));return w;}\nfunction fft(re,im){var n=re.length;for(var i=1,j=0;i<n;i++){var bit=n>>1;for(;j&bit;bit>>=1)j^=bit;j^=bit;if(i<j){var tr=re[i];re[i]=re[j];re[j]=tr;var ti=im[i];im[i]=im[j];im[j]=ti;}}for(var L=2;L<=n;L<<=1){var ang=-2*Math.PI/L;var wr=Math.cos(ang),wi=Math.sin(ang);for(var s=0;s<n;s+=L){var cwr=1,cwi=0;for(var k=0;k<L/2;k++){var a=s+k,b=s+k+L/2;var vr=re[b]*cwr-im[b]*cwi;var vi=re[b]*cwi+im[b]*cwr;re[b]=re[a]-vr;im[b]=im[a]-vi;re[a]+=vr;im[a]+=vi;var ncwr=cwr*wr-cwi*wi;cwi=cwr*wi+cwi*wr;cwr=ncwr;}}}}\nfunction spectrum(sig,Fs){var N0=sig.length;var w=hann(N0);var Nfft=nextPow2(N0);var re=new Float64Array(Nfft),im=new Float64Array(Nfft);var ws=0;for(var i=0;i<N0;i++){re[i]=sig[i]*w[i];ws+=w[i];}fft(re,im);var half=Nfft>>1;var mag=new Float64Array(half),fr=new Float64Array(half);var df=Fs/Nfft;for(var k=0;k<half;k++){var m=Math.sqrt(re[k]*re[k]+im[k]*im[k]);mag[k]=(k===0?1:2)*m/ws;fr[k]=k*df;}return {freqs:fr,mag:mag};}\n\nvar axis = flow.get('axis') || 'Z';\nvar sig = (msg.axes && msg.axes[axis]) ? msg.axes[axis] : null;\nif(!sig || !sig.length){ node.warn('axis '+axis+' empty (WS200 is single-axis)'); return null; }\nvar sp = spectrum(sig, msg.meta.Fs);\nvar half = sp.mag.length;\nvar BINS = 256, step = half/BINS;\nvar bars = new Array(BINS), freqs = new Array(BINS);\nfor(var b=0;b<BINS;b++){\n  var lo=Math.floor(b*step), hi=Math.floor((b+1)*step); if(hi<=lo)hi=lo+1;\n  var mx=0, fAt=sp.freqs[lo];\n  for(var k=lo;k<hi&&k<half;k++){ if(sp.mag[k]>mx){mx=sp.mag[k];fAt=sp.freqs[k];} }\n  bars[b]=mx; freqs[b]=Math.round(fAt);\n}\nnode.status({fill:'blue',shape:'dot',text:axis+' fft ok'});\nreturn { payload:{ axis:axis, serial:msg.meta.serial, time:msg.meta.time,\n  fmax:Math.round(sp.freqs[half-1]), bins:bars, freqs:freqs } };\n",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 640,
    "y": 120,
    "wires": [
      [
        "a360_spec",
        "a360_wf",
        "a360_dbg"
      ]
    ]
  },
