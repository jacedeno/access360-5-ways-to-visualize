  {
    "id": "a360_spec",
    "type": "ui-template",
    "z": "a360_m4_tab",
    "group": "a360_g_spec",
    "page": "",
    "ui": "",
    "name": "Spectrum",
    "order": 1,
    "width": "12",
    "height": "6",
    "head": "",
    "format": "<template>\n  <div style=\"padding:4px\">\n    <canvas ref=\"sp\" width=\"512\" height=\"200\"\n            style=\"width:100%;height:200px;background:#0a0c12;border-radius:4px\"></canvas>\n    <div style=\"color:#9aa;font:12px/1.4 monospace;margin-top:4px\">{{ label }}</div>\n  </div>\n</template>\n<script>\nexport default {\n  data(){ return { label:'waiting for FFT\u2026' } },\n  watch:{ msg(m){\n    if(!m||!m.payload||!m.payload.bins) return\n    const p=m.payload, cv=this.$refs.sp; if(!cv) return\n    const ctx=cv.getContext('2d'), W=cv.width, H=cv.height, bins=p.bins, n=bins.length\n    let max=1e-9; for(let i=0;i<n;i++) if(bins[i]>max) max=bins[i]\n    ctx.fillStyle='#0a0c12'; ctx.fillRect(0,0,W,H)\n    ctx.strokeStyle='#3a8edb'; ctx.lineWidth=1; ctx.beginPath()\n    for(let x=0;x<n;x++){ const px=x/(n-1)*W, py=H-(bins[x]/max)*(H-8)-2; x?ctx.lineTo(px,py):ctx.moveTo(px,py) }\n    ctx.stroke()\n    this.label='sensor '+p.serial+' \u2022 axis '+p.axis+' \u2022 0\u2013'+p.fmax+' Hz \u2022 peak '+max.toExponential(2)+' g'\n  } }\n}\n</script>\n",
    "storeOutMessages": true,
    "passthru": false,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 880,
    "y": 100,
    "wires": [
      []
    ]
  },
  {
    "id": "a360_wf",
    "type": "ui-template",
    "z": "a360_m4_tab",
    "group": "a360_g_wf",
    "page": "",
    "ui": "",
    "name": "Waterfall",
    "order": 1,
    "width": "12",
    "height": "8",
    "head": "",
    "format": "<template>\n  <div style=\"padding:4px\">\n    <canvas ref=\"wf\" width=\"512\" height=\"260\"\n            style=\"width:100%;height:260px;background:#05060a;border-radius:4px\"></canvas>\n    <div style=\"color:#9aa;font:12px/1.4 monospace;margin-top:4px\">{{ label }}</div>\n  </div>\n</template>\n<script>\nexport default {\n  data(){ return { label:'waiting for readings\u2026', gmax:1e-9 } },\n  methods:{ turbo(v){ v=Math.max(0,Math.min(1,v))\n    const r=Math.round(255*Math.min(1,Math.max(0,1.6*v-0.2)))\n    const g=Math.round(255*Math.min(1,Math.max(0, v<0.625?1.6*v-0.1:2-1.6*v)))\n    const b=Math.round(255*Math.min(1,Math.max(0,1.0-1.8*v)))\n    return 'rgb('+r+','+g+','+b+')' } },\n  watch:{ msg(m){\n    if(!m||!m.payload||!m.payload.bins) return\n    const p=m.payload, cv=this.$refs.wf; if(!cv) return\n    const ctx=cv.getContext('2d'), W=cv.width, H=cv.height, bins=p.bins, n=bins.length\n    for(let i=0;i<n;i++) if(bins[i]>this.gmax) this.gmax=bins[i]\n    const img=ctx.getImageData(0,0,W,H-1); ctx.putImageData(img,0,1)\n    for(let x=0;x<W;x++){ const v=bins[Math.floor(x/W*n)]/this.gmax; ctx.fillStyle=this.turbo(v); ctx.fillRect(x,0,1,1) }\n    this.label='sensor '+p.serial+' \u2022 axis '+p.axis+' \u2022 0\u2013'+p.fmax+' Hz \u2022 '+(p.time||'')\n  } }\n}\n</script>\n",
    "storeOutMessages": true,
    "passthru": false,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 880,
    "y": 160,
    "wires": [
      []
    ]
  },
